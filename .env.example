# ──────────────────────────────────────────────────────────
# FinancePro Backend — Variables de entorno
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DB_NAME=freelancer_finance_db
DB_USER=user
DB_PASSWORD=changeme_secret

# Puerto expuesto de PostgreSQL en el host (evita conflicto con Postgres local)
DB_PORT=5444

# Puerto expuesto de la aplicación Spring Boot
APP_PORT=8080
