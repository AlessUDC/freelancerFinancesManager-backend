# ──────────────────────────────────────────────────────────
# FinancePro Backend — Variables de entorno de ejemplo
# ──────────────────────────────────────────────────────────

# Configuración de base de datos para Docker Compose y Local
DATABASE_NAME=dbname
DATABASE_USER=user
DATABASE_PASSWORD=password
DB_PORT=5444

# Puerto de la aplicación Spring Boot
APP_PORT=8080

# JWT — Secreto para firmar tokens. Cambiar en producción por un valor seguro.
JWT_SECRET=qwertyuiop1234567890asdfghjklzxcvbnm1234567890qwertyuiopasdfghjkl
JWT_EXPIRATION_MS=98765432

# Credenciales de usuarios dummy (solo para desarrollo local)
SEED_USER_PASSWORD=test1234
